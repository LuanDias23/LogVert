{{!--
  View do Painel do Cliente (Minhas Solicitações)
  Usa layout: false — estrutura HTML própria para não conflitar com CSS do lojista
--}}
<!doctype html>
<html lang="pt-BR">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <link rel="icon" type="image/png" href="/assets/logosemfundo.png">
    <link rel="stylesheet" href="/pages/menu.cliente/menuCliente.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
</head>

<body>

    <div id="dashboard-particles"></div>

    <div class="dashboard-layout">
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <img src="/assets/logosemfundo.png" alt="Logo LogVert" class="sidebar-logo">
            </div>
            <ul class="sidebar-menu">
                <li><a class="sidebar-link active" href="/cliente/dashboard"><i
                            class="fa-solid fa-receipt"></i><span>Minhas Solicitações</span></a></li>
                <li><a class="sidebar-link" href="/pages/solicitacao/solicitacao.html"><i
                            class="fa-solid fa-plus-circle"></i><span>Nova Solicitação</span></a></li>
                <li><a class="sidebar-link" href="/pages/dados-pessoais/meus_dados.html"><i
                            class="fa-solid fa-user-cog"></i><span>Meus Dados</span></a></li>
                <li><a class="sidebar-link" href="/pages/FAQ_cliente/FAQ.html"><i
                            class="fa-solid fa-question-circle"></i><span>Ajuda</span></a></li>
                <li><a class="sidebar-link" href="/login"><i
                            class="fa-solid fa-arrow-right-from-bracket"></i><span>Sair</span></a></li>
            </ul>

            <div class="sidebar-toggle-wrapper">
                <button class="sidebar-toggle" id="sidebarToggle" title="Minimizar menu">
                    <i class="fa-solid fa-chevron-left"></i>
                </button>
            </div>
        </aside>

        <div class="main-container">
            <header class="main-header">
                <div class="header-content">
                    <button class="mobile-menu-toggle" id="mobileMenuToggle" aria-label="Abrir menu">
                        <i class="fas fa-bars"></i>
                    </button>
                    <h1 class="header-title">Minhas Solicitações</h1>

                    <div class="header-user-actions">
                        <span>Bem-vindo, Cliente</span>
                        <div class="header-actions">
                            <div class="header-action-item">
                                <button class="header-action-btn" id="accountBtn" title="Minha Conta">
                                    <i class="fa-solid fa-user-circle"></i>
                                </button>
                                <div class="dropdown-menu" id="accountDropdown">
                                    <ul>
                                        <li><a href="/pages/dados-pessoais/meus_dados.html"><i class="fa-solid fa-user-cog"></i> Meus Dados</a></li>
                                    </ul>
                                    <div class="dropdown-footer">
                                        <a href="/login" class="logout-link"><i
                                                class="fa-solid fa-arrow-right-from-bracket"></i> Sair</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </header>

            <main class="main-content">
                <a href="/pages/solicitacao/solicitacao.html" class="card-link card-new-request">
                    <div class="card card-action">
                        <i class="fa-solid fa-plus fa-2x"></i>
                        <span class="card-text">INICIAR NOVA TROCA OU DEVOLUÇÃO</span>
                    </div>
                </a>

                <h2 class="section-title">SOLICITAÇÕES EM ANDAMENTO</h2>
                <div class="cards-grid">
                    <div class="card">
                        <div class="card-header">
                            <h3>Pedido #BR1023A</h3>
                            <span class="status-badge status-approved">Aprovado</span>
                        </div>
                        <p class="card-product">Produto: Camiseta Azul P</p>
                        <a href="#" class="card-details">Ver detalhes <i class="fa-solid fa-arrow-right"></i></a>
                    </div>
                    <div class="card">
                        <div class="card-header">
                            <h3>Pedido #BR1019B</h3>
                            <span class="status-badge status-sent">Produto Enviado</span>
                        </div>
                        <p class="card-product">Produto: Calça Jeans 38</p>
                        <a href="#" class="card-details">Rastrear <i class="fa-solid fa-arrow-right"></i></a>
                    </div>
                </div>
            </main>

            <!-- Rodapé Global -->
            <footer class="global-footer">
                <p>© {{year}} LogVert. Todos os direitos reservados.</p>
            </footer>
        </div>
    </div>
    <div class="overlay"></div>

    <script src="https://cdn.jsdelivr.net/npm/particles.js@2.0.0/particles.min.js"></script>
    <script src="/js/api/apiClient.js"></script>
    <script src="/pages/menu.cliente/menuCliente.js"></script>

    <!-- MODAL DETALHES -->
    <div id="modalDetalhes" class="modal-detalhes">
        <div class="modal-detalhes-content">

            <button class="modal-close-btn">
                <i class="fa-solid fa-xmark"></i>
            </button>

            <div class="modal-header">
                <h2 id="modalPedido"></h2>
                <span id="modalStatus" class="status-badge"></span>
            </div>

            <div class="modal-body">
                <p id="modalProduto"></p>

                <div class="modal-info">
                    <p><strong>Data da Solicitação:</strong> 26/03/2026</p>
                    <p><strong>Tipo:</strong> Troca / Devolução</p>
                    <p><strong>Descrição:</strong> Solicitação registrada pelo cliente.</p>
                </div>
            </div>

        </div>
    </div>

</body>

</html>
